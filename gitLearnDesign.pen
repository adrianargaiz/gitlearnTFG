                        },
                        {
                          "type": "text",
                          "id": "E3oQv",
                          "name": "codeLn5",
                          "fill": "$--success",
                          "content": "$ git branch -a",
                          "fontFamily": "JetBrains Mono",
                          "fontSize": 12,
                          "fontWeight": "normal"
